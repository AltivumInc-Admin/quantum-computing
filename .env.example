# AWS Configuration for Amazon Braket
AWS_DEFAULT_REGION=us-east-1
BRAKET_S3_BUCKET=amazon-braket-results-YOUR_ACCOUNT_ID
BRAKET_S3_PREFIX=quantum-workspace
AWS_PROFILE=default

# Budget threshold (USD per month)
BRAKET_MONTHLY_BUDGET=50

# Web portal (web/) — optional. "View on GitHub" links default to the canonical
# repo URL recorded in web/src/lib/content-manifest.json; set this only to point
# a fork/preview deployment at a different repository.
# NEXT_PUBLIC_GITHUB_REPO=https://github.com/AltivumInc-Admin/quantum-computing

.venv/
.cache/
# Self-hosted LAB Pyodide distribution (PyodideAddon well-known path; regenerated by
# build.sh, copied into public/lab/static/pyodide/ by `jupyter lite build`).
static/
# Everything under files/ is staged by build.sh from the curriculum (notebooks,
# lib/) and the qcsim + comm wheels — nothing there is authored. One pattern
# instead of a hand-maintained list of the seven section directories, which the
# manifest already owns (build.sh reads the section list from it precisely so the
# staging loop can never drift; this ignore list used to be able to).
files/*/
.jupyterlite.doit.db
